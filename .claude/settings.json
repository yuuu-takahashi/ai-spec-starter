{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Edit(*)",
      "Write(*)",

      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(pwd:*)",
      "Bash(cd:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(which:*)",

      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "ask": [
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(make:*)",
      "Bash(docker:*)",
      "Bash(gh:*)",
      "Bash(bundle:*)",
      "Bash(rake:*)"
    ],
    "deny": [
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.crt)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",

      "Bash(rm -rf *)",
      "Bash(chmod 777 *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(git.*force:*)",
      "Bash(git.*--hard:*)"
    ]
  },

  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "chrome-devtools",
    "context7",
    "drawio",
    "figma",
    "mermaid-mcp",
    "notion",
    "playwright",
    "serena"
  ],

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-command.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/log-error.sh"
          }
        ]
      }
    ]
  },

  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true
  },

  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline.sh"
  },

  "plansDirectory": "./.claude/plans",
  "outputStyle": "Explanatory",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
